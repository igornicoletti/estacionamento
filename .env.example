# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ERP mock
VITE_ERP_CATALOG_MOCK_ENABLED=false
VITE_OPERATIONAL_MOCK_ENABLED=false

# Auth
VITE_AUTH_DEV_BYPASS=false

# Supabase Edge Function secrets
# Configure with `supabase secrets set`, never expose these in the browser.
APP_HMAC_SECRET=replace_with_strong_random_secret
APP_ALLOWED_ORIGINS=http://localhost:5173,https://estacionamento.redemontecarlo.com.br

# App
# Use the exact dev origin where Vite is running (for example 5173 or 5174).
VITE_APP_ORIGIN=http://localhost:5173
VITE_WEBAUTHN_RP_ID=localhost
